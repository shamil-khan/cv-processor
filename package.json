{
  "name": "cv-processor",
  "version": "0.2.0",
  "description": "This library process user friendly cv files in json, toml and yaml/yml format and delivers typescript model, which we can use for any purpose like redering UI, generate stylish cv docx etc. It supports multi language.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && echo \"✅ Success: Dist Build done. ⚙️ \"",
    "build:dist": "tsup CVProcessor/index.ts --out-dir dist --format cjs,esm --dts --minify --clean && echo \"✅ Success: Release Build done. ⚙️ \"",
    "dev": "tsx --env-file=.env  index.ts",
    "watch": "tsx watch --env-file=.env index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "clean": "rm -rf ./node_modules/ ./.logs ./dist ./pnpm-lock.yaml && echo \"✅ Cleanup done.\""
  },
  "keywords": [
    "CV Parser",
    "CV Document Parser"
  ],
  "author": "Shamil Khan",
  "license": "GNU",
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "awilix": "^12.0.5",
    "pino": "^9.14.0",
    "smol-toml": "^1.4.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ]
}
